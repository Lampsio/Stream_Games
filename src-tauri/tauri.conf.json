{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "words",
  "version": "0.1.1",
  "identifier": "com.daniel.words",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Twitch Word Game",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://raw.githubusercontent.com/Lampsio/Stream_Games/main/updater/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFBNzA5REE0NUZFOTdDNjcKUldSbmZPbGZwSjF3R2grL09TVklGWU9KRHBuZldvU1lJalVIbC9Wd2VQeTZFN1ZrM21WMmg4RWEK"
    }
  }
}
